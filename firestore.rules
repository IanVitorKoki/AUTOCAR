rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isNonEmptyString(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function isPositiveNumber(value) {
      return (value is int || value is float) && value > 0;
    }

    function isNonNegativeNumber(value) {
      return (value is int || value is float) && value >= 0;
    }

    function isIsoDate(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function vehicleDocPath(vehicleId) {
      return /databases/$(database)/documents/vehicles/$(vehicleId);
    }

    function ownsVehicle(vehicleId) {
      return exists(vehicleDocPath(vehicleId)) &&
        get(vehicleDocPath(vehicleId)).data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create, update: if isOwner(userId) &&
        request.resource.data.keys().hasOnly(['uid', 'name', 'email', 'createdAt']) &&
        request.resource.data.uid == userId &&
        isNonEmptyString(request.resource.data.name, 2, 120) &&
        isNonEmptyString(request.resource.data.email, 5, 160);
    }

    match /vehicles/{vehicleId} {
      allow read, delete: if isOwner(resource.data.userId);

      allow create: if signedIn() &&
        request.resource.data.keys().hasOnly([
          'id',
          'userId',
          'nickname',
          'brand',
          'model',
          'year',
          'plate',
          'currentMileage',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.id == vehicleId &&
        request.resource.data.userId == request.auth.uid &&
        isNonEmptyString(request.resource.data.nickname, 2, 80) &&
        isNonEmptyString(request.resource.data.brand, 2, 80) &&
        isNonEmptyString(request.resource.data.model, 2, 80) &&
        (request.resource.data.year is int) &&
        request.resource.data.year >= 1900 &&
        request.resource.data.year <= 2100 &&
        request.resource.data.plate is string &&
        request.resource.data.plate.matches('^[A-Z]{3}[0-9][A-Z0-9][0-9]{2}$') &&
        isNonNegativeNumber(request.resource.data.currentMileage);

      allow update: if isOwner(resource.data.userId) &&
        request.resource.data.keys().hasOnly([
          'id',
          'userId',
          'nickname',
          'brand',
          'model',
          'year',
          'plate',
          'currentMileage',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.id == vehicleId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        isNonEmptyString(request.resource.data.nickname, 2, 80) &&
        isNonEmptyString(request.resource.data.brand, 2, 80) &&
        isNonEmptyString(request.resource.data.model, 2, 80) &&
        (request.resource.data.year is int) &&
        request.resource.data.year >= 1900 &&
        request.resource.data.year <= 2100 &&
        request.resource.data.plate is string &&
        request.resource.data.plate.matches('^[A-Z]{3}[0-9][A-Z0-9][0-9]{2}$') &&
        isNonNegativeNumber(request.resource.data.currentMileage);
    }

    match /maintenances/{maintenanceId} {
      allow read, delete: if isOwner(resource.data.userId);

      allow create: if signedIn() &&
        request.resource.data.keys().hasOnly([
          'id',
          'userId',
          'vehicleId',
          'type',
          'description',
          'date',
          'cost',
          'mileage',
          'notes',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.id == maintenanceId &&
        request.resource.data.userId == request.auth.uid &&
        ownsVehicle(request.resource.data.vehicleId) &&
        isNonEmptyString(request.resource.data.type, 3, 60) &&
        isNonEmptyString(request.resource.data.description, 3, 180) &&
        isIsoDate(request.resource.data.date) &&
        isPositiveNumber(request.resource.data.cost) &&
        isNonNegativeNumber(request.resource.data.mileage) &&
        request.resource.data.notes is string &&
        request.resource.data.notes.size() <= 400;

      allow update: if isOwner(resource.data.userId) &&
        request.resource.data.keys().hasOnly([
          'id',
          'userId',
          'vehicleId',
          'type',
          'description',
          'date',
          'cost',
          'mileage',
          'notes',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.id == maintenanceId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        ownsVehicle(request.resource.data.vehicleId) &&
        isNonEmptyString(request.resource.data.type, 3, 60) &&
        isNonEmptyString(request.resource.data.description, 3, 180) &&
        isIsoDate(request.resource.data.date) &&
        isPositiveNumber(request.resource.data.cost) &&
        isNonNegativeNumber(request.resource.data.mileage) &&
        request.resource.data.notes is string &&
        request.resource.data.notes.size() <= 400;
    }

    match /expenses/{expenseId} {
      allow read, delete: if isOwner(resource.data.userId);

      allow create: if signedIn() &&
        request.resource.data.keys().hasOnly([
          'id',
          'userId',
          'vehicleId',
          'category',
          'description',
          'cost',
          'date',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.id == expenseId &&
        request.resource.data.userId == request.auth.uid &&
        ownsVehicle(request.resource.data.vehicleId) &&
        isNonEmptyString(request.resource.data.category, 3, 60) &&
        isNonEmptyString(request.resource.data.description, 3, 180) &&
        isPositiveNumber(request.resource.data.cost) &&
        isIsoDate(request.resource.data.date);

      allow update: if isOwner(resource.data.userId) &&
        request.resource.data.keys().hasOnly([
          'id',
          'userId',
          'vehicleId',
          'category',
          'description',
          'cost',
          'date',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.id == expenseId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        ownsVehicle(request.resource.data.vehicleId) &&
        isNonEmptyString(request.resource.data.category, 3, 60) &&
        isNonEmptyString(request.resource.data.description, 3, 180) &&
        isPositiveNumber(request.resource.data.cost) &&
        isIsoDate(request.resource.data.date);
    }
  }
}

